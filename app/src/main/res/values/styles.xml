<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorSecondary">@color/colorPrimary</item>
        <item name="colorControlActivated">@color/colorPrimary</item>
    </style>

    <style name="Toolbar.TitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">15sp</item>
        <item name="android:layout_gravity">center_horizontal</item>
    </style>

    <style name="CompactCheckBox" parent="Widget.AppCompat.CompoundButton.CheckBox">
        <item name="android:includeFontPadding">false</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingRight">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:textColor">@color/colorText</item>
        <item name="android:textSize">@dimen/text_size</item>
    </style>

    <style name="AppSection.Panel" parent="@android:style/Widget">
        <item name="android:background">@drawable/bg_bridge_combination_panel</item>
    </style>

    <style name="AppSection.Title" parent="@android:style/TextAppearance">
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textSize">@dimen/text_size_big</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppButton.Base" parent="Widget.AppCompat.Button">
        <item name="android:gravity">center</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingLeft">@dimen/padding_15dp</item>
        <item name="android:paddingTop">@dimen/padding_10dp</item>
        <item name="android:paddingRight">@dimen/padding_15dp</item>
        <item name="android:paddingBottom">@dimen/padding_10dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:translationZ">0dp</item>
    </style>

    <style name="AppButton.Primary" parent="AppButton.Base">
        <item name="android:background">@drawable/bg_action_pill_outline</item>
        <item name="backgroundTint">@null</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>

    <style name="AppButton.Filter" parent="AppButton.Primary">
        <item name="android:paddingLeft">@dimen/padding_8dp</item>
        <item name="android:paddingTop">@dimen/padding_5dp</item>
        <item name="android:paddingRight">@dimen/padding_8dp</item>
        <item name="android:paddingBottom">@dimen/padding_5dp</item>
        <item name="android:textSize">@dimen/text_size_small</item>
    </style>

    <style name="AppButton.PrimarySolid" parent="AppButton.Base">
        <item name="android:background">@drawable/bg_action_pill_outline</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>

    <style name="AppButton.Outline" parent="AppButton.Base">
        <item name="android:background">@drawable/bg_action_pill_outline</item>
        <item name="android:paddingTop">@dimen/padding_8dp</item>
        <item name="android:paddingBottom">@dimen/padding_8dp</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>

    <style name="AppButton.Cancel" parent="AppButton.Base">
        <item name="android:background">@drawable/border_corners_cancel</item>
        <item name="android:textColor">@color/colorText</item>
    </style>

    <style name="AppTextButton.Base" parent="@android:style/Widget.TextView">
        <item name="android:gravity">center</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:padding">@dimen/padding_10dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_size</item>
        <item name="android:translationZ">0dp</item>
    </style>

    <style name="AppTextButton.Primary" parent="AppTextButton.Base">
        <item name="android:background">@drawable/bg_action_pill_outline</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>

    <style name="AppTextButton.TopNav" parent="AppTextButton.Primary">
        <item name="android:background">@drawable/bg_action_pill_outline</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:paddingLeft">@dimen/padding_5dp</item>
        <item name="android:paddingTop">@dimen/padding_8dp</item>
        <item name="android:paddingRight">@dimen/padding_5dp</item>
        <item name="android:paddingBottom">@dimen/padding_8dp</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textSize">@dimen/text_size</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="AppTextButton.Action" parent="AppTextButton.Primary">
        <item name="android:background">@drawable/bg_action_pill_outline</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:paddingLeft">@dimen/padding_8dp</item>
        <item name="android:paddingTop">@dimen/padding_8dp</item>
        <item name="android:paddingRight">@dimen/padding_8dp</item>
        <item name="android:paddingBottom">@dimen/padding_8dp</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textSize">@dimen/text_size</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="AppEditText.Box" parent="@android:style/Widget.EditText">
        <item name="android:background">@drawable/bg_input_box</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingLeft">@dimen/padding_8dp</item>
        <item name="android:paddingTop">@dimen/padding_5dp</item>
        <item name="android:paddingRight">@dimen/padding_8dp</item>
        <item name="android:paddingBottom">@dimen/padding_5dp</item>
        <item name="android:textColor">@color/colorText</item>
        <item name="android:textSize">@dimen/text_size</item>
    </style>

    <style name="AppAuth.EditText" parent="AppEditText.Box">
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:paddingTop">@dimen/padding_8dp</item>
        <item name="android:paddingBottom">@dimen/padding_8dp</item>
    </style>

    <style name="AppFilter" />

    <style name="AppFilter.Panel" parent="@android:style/Widget">
        <item name="android:background">@drawable/bg_filter_panel</item>
        <item name="android:padding">@dimen/padding_5dp</item>
    </style>

    <style name="AppFilter.Label" parent="@android:style/TextAppearance">
        <item name="android:textColor">@color/colorText</item>
        <item name="android:textSize">@dimen/text_size_small</item>
    </style>

    <style name="AppFilter.Input" parent="AppEditText.Box">
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppFilter.Spinner">
        <item name="android:background">@drawable/bg_spinner_dropdown</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingLeft">@dimen/padding_5dp</item>
        <item name="android:paddingRight">28dp</item>
        <item name="android:spinnerMode">dropdown</item>
    </style>

    <style name="AppTextButton.Cancel" parent="AppTextButton.Base">
        <item name="android:background">@drawable/border_corners_cancel</item>
        <item name="android:textColor">@color/colorText</item>
    </style>

    <style name="AppTextButton.Copy" parent="AppTextButton.Base">
        <item name="android:background">@drawable/bg_button_copy</item>
        <item name="android:textColor">@color/colorText</item>
    </style>

    <style name="AppTextButton.AuthSignIn" parent="AppTextButton.Base">
        <item name="android:background">@drawable/boder_tv_dangnhap</item>
        <item name="android:padding">6dp</item>
        <item name="android:textColor">@color/colorThemeBold</item>
    </style>

    <style name="AppTextButton.AuthSignUp" parent="AppTextButton.Base">
        <item name="android:background">@drawable/border_tv_dangky</item>
        <item name="android:padding">6dp</item>
        <item name="android:textColor">@color/colorWhite</item>
    </style>

</resources>
