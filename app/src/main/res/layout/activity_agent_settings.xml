<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgRowLottery"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_toolbar"
        android:background="@color/colorThemeBold">

        <TextView
            android:id="@+id/tvToolbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="@dimen/padding_5dp"
            android:text="Thêm model"
            android:textColor="@color/colorThemeLight"
            android:textSize="@dimen/text_size_header" />

    </androidx.appcompat.widget.Toolbar>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_bridge_combination_panel"
                android:orientation="vertical"
                android:padding="@dimen/padding_10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Provider"
                    android:textColor="@color/colorPrimary"
                    android:textSize="@dimen/text_size_title"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spnProvider"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="@dimen/margin_5dp"
                    android:background="@drawable/bg_spinner_dropdown"
                    android:paddingLeft="@dimen/padding_10dp"
                    android:paddingRight="32dp"
                    android:spinnerMode="dropdown" />

                <EditText
                style="@style/AppEditText.Box"
                    android:id="@+id/edtProvider"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="@dimen/margin_5dp"
                    android:hint="Provider tùy chỉnh"
                    android:singleLine="true"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_10dp"
                    android:text="Tên cấu hình"
                    android:textColor="@color/colorPrimary"
                    android:textSize="@dimen/text_size_title"
                    android:textStyle="bold" />

                <EditText
                style="@style/AppEditText.Box"
                    android:id="@+id/edtProfileName"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="@dimen/margin_5dp"
                    android:singleLine="true" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_10dp"
                    android:text="Base URL"
                    android:textColor="@color/colorPrimary"
                    android:textSize="@dimen/text_size_title"
                    android:textStyle="bold" />

                <EditText
                style="@style/AppEditText.Box"
                    android:id="@+id/edtBaseUrl"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="@dimen/margin_5dp"
                    android:inputType="textUri"
                    android:singleLine="true" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_10dp"
                    android:text="Model"
                    android:textColor="@color/colorPrimary"
                    android:textSize="@dimen/text_size_title"
                    android:textStyle="bold" />

                <EditText
                style="@style/AppEditText.Box"
                    android:id="@+id/edtModel"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="@dimen/margin_5dp"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/btnLoadModels"
                    style="@style/AppButton.Outline"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="@dimen/margin_5dp"
                    android:text="Tải danh sách model" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_10dp"
                    android:text="API key"
                    android:textColor="@color/colorPrimary"
                    android:textSize="@dimen/text_size_title"
                    android:textStyle="bold" />

                <EditText
                style="@style/AppEditText.Box"
                    android:id="@+id/edtApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="@dimen/margin_5dp"
                    android:inputType="textPassword"
                    android:singleLine="true" />

            </LinearLayout>

            <Button
                android:id="@+id/btnAdd"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="@dimen/margin_10dp"
                android:text="Thêm" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
