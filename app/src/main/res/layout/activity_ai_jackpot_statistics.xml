<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgRowLottery"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_toolbar"
        android:background="@color/colorThemeBold">

        <TextView
            android:id="@+id/tvToolbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:padding="@dimen/padding_5dp"
            android:text="AI soi cầu ĐB"
            android:textColor="@color/colorThemeLight"
            android:textSize="@dimen/text_size_header" />

        <Button
            android:id="@+id/btnSelectModel"
            style="@style/AppButton.Outline"
            android:layout_width="155dp"
            android:layout_height="40dp"
            android:layout_gravity="right|center_vertical"
            android:layout_marginRight="@dimen/margin_10dp"
            android:singleLine="true"
            android:text="Model"
            android:textSize="12sp" />

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_10dp">

            <TextView
                android:id="@+id/tvNotice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_bridge_combination_panel"
                android:lineSpacingExtra="3dp"
                android:padding="@dimen/padding_10dp"
                android:text="AI chỉ phân tích dữ liệu ĐB đã lưu trong app, kết quả chỉ dùng để tham khảo."
                android:textColor="@color/colorText"
                android:textSize="@dimen/text_size" />

            <Button
                android:id="@+id/btnPredictionHistory"
                style="@style/AppButton.Outline"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="@dimen/margin_5dp"
                android:text="Lịch sử AI" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_10dp"
                android:text="Soi cầu ĐB"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/text_size_big"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBridgeAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_5dp"
                android:background="@drawable/bg_chat_user_message"
                android:lineSpacingExtra="3dp"
                android:padding="@dimen/padding_10dp"
                android:textColor="@color/colorThemeLight"
                android:textSize="@dimen/text_size" />

            <Button
                android:id="@+id/btnAskBridge"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="@dimen/margin_5dp"
                android:text="Soi cầu ĐB" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_10dp"
                android:text="Thống kê ĐB"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/text_size_big"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLocalStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_5dp"
                android:background="@drawable/bg_chat_bot_message"
                android:lineSpacingExtra="3dp"
                android:padding="@dimen/padding_10dp"
                android:textColor="@color/colorText"
                android:textSize="@dimen/text_size" />

            <TextView
                android:id="@+id/tvStatsAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_5dp"
                android:background="@drawable/bg_chat_user_message"
                android:lineSpacingExtra="3dp"
                android:padding="@dimen/padding_10dp"
                android:textColor="@color/colorThemeLight"
                android:textSize="@dimen/text_size" />

            <Button
                android:id="@+id/btnAskStats"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="@dimen/margin_5dp"
                android:text="Thống kê ĐB" />

        </LinearLayout>

    </ScrollView>

    <Button
        android:id="@+id/btnStop"
        style="@style/AppButton.Outline"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_margin="@dimen/margin_5dp"
        android:enabled="false"
        android:text="Dừng AI" />

</LinearLayout>
