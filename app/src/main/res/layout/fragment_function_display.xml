<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorSurfaceSoft"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurfaceSoft"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/padding_10dp"
        android:paddingTop="@dimen/padding_8dp"
        android:paddingRight="@dimen/padding_10dp"
        android:paddingBottom="@dimen/padding_8dp">

        <ImageView
            android:id="@+id/imgPersonal"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginRight="@dimen/margin_6dp"
            android:background="@drawable/bg_search_box"
            android:contentDescription="Cá nhân"
            android:padding="@dimen/padding_8dp"
            android:src="@drawable/ic_bottom_personal"
            app:tint="@color/colorPrimary" />

        <LinearLayout
            android:id="@+id/layoutSearch"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_box"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/padding_10dp"
            android:paddingRight="@dimen/padding_10dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_search" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_10dp"
                android:layout_weight="1"
                android:singleLine="true"
                android:text="Tìm kiếm"
                android:textColor="@color/colorTextNavBar"
                android:textSize="@dimen/text_size" />

        </LinearLayout>

        <ImageView
            android:id="@+id/imgNotification"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginLeft="@dimen/margin_6dp"
            android:background="@drawable/bg_search_box"
            android:contentDescription="Thông báo"
            android:padding="@dimen/padding_8dp"
            android:src="@drawable/ic_notification" />

        <ImageView
            android:id="@+id/imgNavigationMenu"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginLeft="@dimen/margin_6dp"
            android:background="@drawable/bg_search_box"
            android:contentDescription="Menu"
            android:padding="@dimen/padding_8dp"
            android:src="@drawable/ic_menu_lines" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/colorSurfaceSoft"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/padding_8dp"
            android:paddingRight="@dimen/padding_8dp"
            android:paddingBottom="@dimen/padding_10dp">

            <LinearLayout
                android:id="@+id/linearLeftGroups"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/margin_5dp"
                android:layout_weight="1"
                android:orientation="vertical" />

            <LinearLayout
                android:id="@+id/linearRightGroups"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_5dp"
                android:layout_weight="1"
                android:orientation="vertical" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
