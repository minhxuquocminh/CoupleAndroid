<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorSurfaceSoft"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorSurfaceSoft">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="@dimen/margin_15dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorSurfaceSoft"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="@dimen/padding_10dp"
                android:paddingTop="@dimen/padding_8dp"
                android:paddingRight="@dimen/padding_10dp"
                android:paddingBottom="@dimen/padding_8dp">

                <ImageView
                    android:id="@+id/imgPersonal"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginRight="@dimen/margin_6dp"
                    android:background="@drawable/bg_search_box"
                    android:contentDescription="Cá nhân"
                    android:padding="@dimen/padding_8dp"
                    android:src="@drawable/ic_bottom_personal"
                    app:tint="@color/colorPrimary" />

                <LinearLayout
                    android:id="@+id/layoutSearch"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search_box"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="@dimen/padding_10dp"
                    android:paddingRight="@dimen/padding_10dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_search" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/margin_10dp"
                        android:layout_weight="1"
                        android:singleLine="true"
                        android:text="Tìm kiếm"
                        android:textColor="@color/colorTextNavBar"
                        android:textSize="@dimen/text_size" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/imgNotification"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginLeft="@dimen/margin_6dp"
                    android:background="@drawable/bg_search_box"
                    android:contentDescription="Thông báo"
                    android:padding="@dimen/padding_8dp"
                    android:src="@drawable/ic_notification" />

                <ImageView
                    android:id="@+id/imgNavigationMenu"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginLeft="@dimen/margin_6dp"
                    android:background="@drawable/bg_search_box"
                    android:contentDescription="Menu"
                    android:padding="@dimen/padding_8dp"
                    android:src="@drawable/ic_menu_lines" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_5dp"
                android:layout_marginRight="@dimen/margin_5dp"
                android:layout_marginBottom="@dimen/margin_6dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/tvViewCombineBridge"
                    style="@style/AppTextButton.TopNav"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginLeft="@dimen/margin_3dp"
                    android:layout_marginRight="@dimen/margin_3dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:minHeight="44dp"
                    android:paddingTop="@dimen/padding_8dp"
                    android:paddingBottom="@dimen/padding_8dp"
                    android:text="Xem cầu"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_size" />

                <Button
                    android:id="@+id/tvViewCycle"
                    style="@style/AppTextButton.TopNav"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginLeft="@dimen/margin_3dp"
                    android:layout_marginRight="@dimen/margin_3dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:minHeight="44dp"
                    android:paddingTop="@dimen/padding_8dp"
                    android:paddingBottom="@dimen/padding_8dp"
                    android:text="Can chi"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_size" />

                <Button
                    android:id="@+id/tvReference"
                    style="@style/AppTextButton.TopNav"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginLeft="@dimen/margin_3dp"
                    android:layout_marginRight="@dimen/margin_3dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:minHeight="44dp"
                    android:paddingTop="@dimen/padding_8dp"
                    android:paddingBottom="@dimen/padding_8dp"
                    android:text="T.khảo"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_size" />

                <Button
                    android:id="@+id/tvQuickCreate"
                    style="@style/AppTextButton.TopNav"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginLeft="@dimen/margin_3dp"
                    android:layout_marginRight="@dimen/margin_3dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:minHeight="44dp"
                    android:paddingTop="@dimen/padding_8dp"
                    android:paddingBottom="@dimen/padding_8dp"
                    android:text="T.nhanh"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_size" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/padding_8dp"
                android:layout_marginRight="@dimen/padding_8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bộ số:"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <EditText
                    android:id="@+id/edtSet"
                    style="@style/AppEditText.Box"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginRight="@dimen/margin_5dp"
                    android:layout_weight="2"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Chạm:"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <EditText
                    android:id="@+id/edtTouch"
                    style="@style/AppEditText.Box"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/padding_8dp"
                android:layout_marginRight="@dimen/padding_8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tổng:"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <EditText
                    android:id="@+id/edtSum"
                    style="@style/AppEditText.Box"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginRight="@dimen/margin_5dp"
                    android:layout_weight="2"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Chi:"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <EditText
                    android:id="@+id/edtBranch"
                    style="@style/AppEditText.Box"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/padding_8dp"
                android:layout_marginRight="@dimen/padding_8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Đầu:"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <EditText
                    android:id="@+id/edtHead"
                    style="@style/AppEditText.Box"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginRight="@dimen/margin_5dp"
                    android:layout_weight="2"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Đuôi:"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <EditText
                    android:id="@+id/edtTail"
                    style="@style/AppEditText.Box"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/padding_8dp"
                android:layout_marginRight="@dimen/padding_8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="K.hợp:"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <EditText
                    android:id="@+id/edtCombineNumber"
                    style="@style/AppEditText.Box"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="5"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/padding_8dp"
                android:layout_marginRight="@dimen/padding_8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Thêm:"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <EditText
                    android:id="@+id/edtAddingNumber"
                    style="@style/AppEditText.Box"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="5"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/padding_8dp"
                android:layout_marginRight="@dimen/padding_8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bỏ:"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <EditText
                    android:id="@+id/edtRemovingNumber"
                    style="@style/AppEditText.Box"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="5"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/padding_8dp"
                android:layout_marginRight="@dimen/padding_8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Càng 3:"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />

                <EditText
                    android:id="@+id/edtThirdClaw"
                    style="@style/AppEditText.Box"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="5"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/text_size" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_5dp"
                android:layout_marginTop="@dimen/margin_5dp"
                android:layout_marginRight="@dimen/margin_5dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/tvCreate"
                        style="@style/AppTextButton.Action"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginLeft="@dimen/margin_3dp"
                        android:layout_marginRight="@dimen/margin_3dp"
                        android:minHeight="44dp"
                        android:padding="@dimen/padding_8dp"
                        android:text="  Tạo  "
                        android:textSize="@dimen/text_size" />

                    <TextView
                        android:id="@+id/tvArrayCounter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginLeft="@dimen/margin_3dp"
                        android:layout_marginTop="@dimen/margin_15dp"
                        android:layout_marginRight="@dimen/margin_3dp"
                        android:text="0 số"
                        android:textColor="@color/colorText"
                        android:textSize="@dimen/text_size" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <EditText
                        android:id="@+id/edtNumberArray"
                        style="@style/AppEditText.Box"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="top"
                        android:lineSpacingExtra="2dp"
                        android:minLines="4"
                        android:textColor="@color/colorText"
                        android:textSize="@dimen/text_size" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_5dp"
                android:layout_marginTop="@dimen/margin_2dp"
                android:layout_marginRight="@dimen/margin_5dp"
                android:layout_marginBottom="@dimen/margin_5dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/tvExportCouple"
                    style="@style/AppTextButton.Action"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginLeft="@dimen/margin_3dp"
                    android:layout_marginRight="@dimen/margin_3dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:minHeight="44dp"
                    android:padding="@dimen/padding_8dp"
                    android:text="Nạp lên"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_size" />

                <Button
                    android:id="@+id/tvExportTriad"
                    style="@style/AppTextButton.Action"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginLeft="@dimen/margin_3dp"
                    android:layout_marginRight="@dimen/margin_3dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:minHeight="44dp"
                    android:padding="@dimen/padding_8dp"
                    android:text="N.xuống"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_size" />

                <Button
                    android:id="@+id/tvExport"
                    style="@style/AppTextButton.Action"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginLeft="@dimen/margin_3dp"
                    android:layout_marginRight="@dimen/margin_3dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:minHeight="44dp"
                    android:padding="@dimen/padding_8dp"
                    android:text="Xuất"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_size" />

                <Button
                    android:id="@+id/tvClear"
                    style="@style/AppTextButton.Action"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginLeft="@dimen/margin_3dp"
                    android:layout_marginRight="@dimen/margin_3dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:minHeight="44dp"
                    android:padding="@dimen/padding_8dp"
                    android:text="Tạo lại"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_size" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/padding_8dp"
                android:layout_marginTop="@dimen/margin_5dp"
                android:layout_marginRight="@dimen/padding_8dp"
                android:layout_marginBottom="@dimen/margin_5dp"
                android:text="Tạo dàn 3 càng"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/text_size_title"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_5dp"
                android:layout_marginRight="@dimen/margin_5dp"
                android:layout_marginBottom="@dimen/margin_5dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/tvViewJackpot"
                    style="@style/AppTextButton.Action"
                    android:layout_width="92dp"
                    android:layout_height="44dp"
                    android:layout_marginLeft="@dimen/margin_3dp"
                    android:layout_marginRight="@dimen/margin_3dp"
                    android:gravity="center"
                    android:minHeight="44dp"
                    android:padding="@dimen/padding_8dp"
                    android:text="  Bảng ĐB  "
                    android:textSize="@dimen/text_size" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSubJackpot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/margin_5dp"
                        android:layout_marginRight="@dimen/margin_5dp"
                        android:gravity="left|center_vertical"
                        android:text="11385\n22486"
                        android:textColor="@color/colorText"
                        android:textSize="@dimen/text_size_big" />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/imgClear"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_marginLeft="@dimen/margin_2dp"
                            android:layout_marginRight="@dimen/margin_2dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_icon_button"
                            android:padding="@dimen/padding_10dp"
                            android:src="@drawable/ic_cancel" />

                        <ImageView
                            android:id="@+id/imgSave"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_marginLeft="@dimen/margin_2dp"
                            android:layout_marginRight="@dimen/margin_2dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_icon_button"
                            android:padding="@dimen/padding_10dp"
                            android:src="@drawable/ic_save" />

                        <ImageView
                            android:id="@+id/imgExport"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_marginLeft="@dimen/margin_2dp"
                            android:layout_marginRight="@dimen/margin_2dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_icon_button"
                            android:padding="@dimen/padding_10dp"
                            android:src="@drawable/ic_export" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNumberCounter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/margin_5dp"
                        android:gravity="center"
                        android:text="0 số được chọn"
                        android:textColor="@color/colorText"
                        android:textSize="@dimen/text_size"
                        android:textStyle="italic" />

                </LinearLayout>

            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/hsThirdClaw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/margin_6dp"
                android:scrollbars="horizontal|vertical" />

            <HorizontalScrollView
                android:id="@+id/hsNumberTable1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/margin_6dp"
                android:scrollbars="horizontal|vertical" />

            <TextView
                android:id="@+id/tvShowTriadList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/padding_8dp"
                android:lineSpacingExtra="2dp"
                android:text="Dàn số 3 càng (đã lưu):"
                android:textColor="@color/colorText"
                android:textSize="@dimen/text_size" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
