<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorThemeLight"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_toolbar"
        android:background="@color/colorThemeBold">

        <TextView
            android:id="@+id/tvToolbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="@dimen/padding_5dp"
            android:text="Thống kê ĐB theo năm"
            android:textColor="@color/colorThemeLight"
            android:textSize="@dimen/text_size_header"
            android:typeface="normal" />

    </androidx.appcompat.widget.Toolbar>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                style="@style/AppFilter.Panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/margin_5dp"
                android:orientation="vertical">

                <TextView
                    style="@style/AppFilter.Label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bộ lọc" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_5dp"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/spnStatisticType"
                        style="@style/AppFilter.Spinner"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginRight="@dimen/margin_5dp"
                        android:layout_weight="5" />

                    <EditText
                        android:id="@+id/edtFilterValue"
                        style="@style/AppFilter.Input"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="3"
                        android:hint="Số đề"
                        android:inputType="number"
                        android:maxLength="2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_5dp"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/AppFilter.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginRight="@dimen/margin_5dp"
                        android:text="Số năm" />

                    <Spinner
                        android:id="@+id/spnNumberOfYears"
                        style="@style/AppFilter.Spinner"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginRight="@dimen/margin_5dp"
                        android:layout_weight="3" />

                    <TextView
                        style="@style/AppFilter.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginRight="@dimen/margin_5dp"
                        android:text="Sắp xếp" />

                    <Spinner
                        android:id="@+id/spnSortType"
                        style="@style/AppFilter.Spinner"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="6" />
                </LinearLayout>

                <Button
                    android:id="@+id/tvFilter"
                    style="@style/AppButton.Filter"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="@dimen/margin_5dp"
                    android:text="Xem" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_5dp"
                android:layout_marginRight="@dimen/margin_5dp"
                android:layout_marginBottom="@dimen/margin_5dp"
                android:text="Kết quả:"
                android:textColor="@color/colorText"
                android:textSize="@dimen/text_size" />

            <LinearLayout
                android:id="@+id/linearFreqCouple"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/margin_5dp"
                android:layout_marginRight="@dimen/margin_5dp"
                android:layout_marginBottom="@dimen/margin_5dp"
                android:orientation="vertical" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
