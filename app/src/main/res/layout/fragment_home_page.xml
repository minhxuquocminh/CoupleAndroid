<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorSurfaceSoft"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorSurfaceSoft">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/padding_15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorSurfaceSoft"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="@dimen/padding_10dp"
                android:paddingTop="@dimen/padding_8dp"
                android:paddingRight="@dimen/padding_10dp"
                android:paddingBottom="@dimen/padding_8dp">

                <ImageView
                    android:id="@+id/imgPersonal"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginRight="@dimen/margin_6dp"
                    android:background="@drawable/bg_search_box"
                    android:contentDescription="Cá nhân"
                    android:padding="@dimen/padding_8dp"
                    android:src="@drawable/ic_bottom_personal"
                    app:tint="@color/colorPrimary" />

                <LinearLayout
                    android:id="@+id/layoutSearch"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search_box"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="@dimen/padding_10dp"
                    android:paddingRight="@dimen/padding_10dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_search" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/margin_10dp"
                        android:layout_weight="1"
                        android:singleLine="true"
                        android:text="Tìm kiếm"
                        android:textColor="@color/colorTextNavBar"
                        android:textSize="@dimen/text_size" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/imgNotification"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginLeft="@dimen/margin_6dp"
                    android:background="@drawable/bg_search_box"
                    android:contentDescription="Thông báo"
                    android:padding="@dimen/padding_8dp"
                    android:src="@drawable/ic_notification" />

                <ImageView
                    android:id="@+id/imgNavigationMenu"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginLeft="@dimen/margin_6dp"
                    android:background="@drawable/bg_search_box"
                    android:contentDescription="Menu"
                    android:padding="@dimen/padding_8dp"
                    android:src="@drawable/ic_menu_lines" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_10dp"
                android:layout_marginRight="@dimen/margin_10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCalendar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Đang cập nhật thời gian..."
                    android:textColor="@color/colorPrimary"
                    android:textSize="@dimen/text_size"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layoutRefreshAll"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginLeft="@dimen/margin_10dp"
                    android:background="@drawable/bg_action_pill_outline"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingLeft="@dimen/padding_10dp"
                    android:paddingRight="@dimen/padding_10dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_autorenew"
                        app:tint="@color/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/margin_5dp"
                        android:text="Cập nhật"
                        android:textColor="@color/colorPrimary"
                        android:textSize="@dimen/text_size_small"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tvJackpotToday"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_10dp"
                android:layout_marginTop="8dp"
                android:layout_marginRight="@dimen/margin_10dp"
                android:background="@drawable/bg_app_panel"
                android:gravity="center"
                android:padding="@dimen/padding_8dp"
                android:text="Xổ số Đặc Biệt hôm nay về: "
                android:textColor="@color/colorThemeBold"
                android:textSize="@dimen/text_size" />

            <TextView
                android:id="@+id/tvJackpotLastDay"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_10dp"
                android:layout_marginTop="@dimen/margin_5dp"
                android:layout_marginRight="@dimen/margin_10dp"
                android:background="@drawable/bg_app_panel"
                android:gravity="center"
                android:padding="@dimen/padding_8dp"
                android:text="Xổ số Đ.Biệt ngày trước đó: "
                android:textColor="@color/colorThemeBold"
                android:textSize="@dimen/text_size" />

            <LinearLayout
                android:id="@+id/layoutRecentJackpots"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:layout_marginLeft="@dimen/margin_10dp"
                android:layout_marginTop="8dp"
                android:layout_marginRight="@dimen/margin_10dp"
                android:baselineAligned="false"
                android:orientation="horizontal" />

            <LinearLayout
                android:id="@+id/layoutQuickGroups"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_10dp"
                android:layout_marginTop="3dp"
                android:layout_marginRight="@dimen/margin_10dp"
                android:orientation="vertical" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
