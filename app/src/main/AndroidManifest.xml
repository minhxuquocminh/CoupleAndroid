<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <receiver
            android:name=".Custom.Handler.Notification.UpdateDataAlarm"
            android:enabled="true"
            android:exported="true"
            android:permission="TODO"
            tools:ignore="ExportedReceiver" />

        <receiver
            android:name=".Custom.Handler.Notification.ManualUpdateDataAlarm"
            android:enabled="true"
            android:exported="true"
            android:permission="TODO"
            tools:ignore="ExportedReceiver" />

        <receiver
            android:name=".Custom.Handler.Notification.NextDayBridgeAlarm"
            android:enabled="true"
            android:exported="true"
            android:permission="TODO"
            tools:ignore="ExportedReceiver" />

        <activity
            android:name=".View.Main.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustPan|stateHidden"
            tools:ignore=",DiscouragedApi,LockedOrientationActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".View.Agent.AgentChatActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".View.Agent.AgentChatHistoryActivity"
            android:windowSoftInputMode="adjustPan|stateHidden" />

        <activity
            android:name=".View.Agent.AgentSettingsActivity"
            android:label="Thêm model"
            android:windowSoftInputMode="adjustPan|stateHidden" />

        <activity
            android:name=".View.Agent.AgentModelManageActivity"
            android:label="Quản lý model"
            android:windowSoftInputMode="adjustPan|stateHidden" />

        <activity
            android:name=".View.Agent.AiJackpotStatisticsActivity"
            android:windowSoftInputMode="adjustPan|stateHidden" />

        <activity android:name=".View.Agent.AiPredictionHistoryActivity" />

        <activity android:name=".View.Bridge.FindingBridgeActivity" />

        <activity android:name=".View.Bridge.AfterDoubleBridgeActivity" />

        <activity android:name=".View.Bridge.ConnectedBridgeActivity" />

        <activity android:name=".View.Bridge.EstimatedBridgeActivity" />

        <activity android:name=".View.Bridge.MappingBridgeActivity" />

        <activity android:name=".View.Bridge.TouchBridgeActivity" />

        <activity android:name=".View.Bridge.SelectiveBridgeActivity" />

        <activity android:name=".View.Jackpot.JackpotNextDayActivity" />

        <activity
            android:name=".View.Lottery.LotteryActivity"
            android:windowSoftInputMode="stateHidden" />

        <activity android:name=".View.Couple.BalanceCoupleActivity" />

        <activity android:name=".View.Couple.CoupleByWeekActivity" />

        <activity android:name=".View.JackpotStatistics.YearlyJackpotStatisticsActivity" />

        <activity android:name=".View.JackpotStatistics.CurrentYearJackpotStatisticsActivity" />


        <activity
            android:name=".View.Jackpot.JackpotByYearActivity"
            android:windowSoftInputMode="stateHidden" />

        <activity android:name=".View.Bridge.ReferenceBridgeActivity" />

        <activity android:name=".View.Bridge.BridgeCombinationActivity" />

        <activity android:name=".View.SubScreen.ExperianceActivity" />

        <activity android:name=".View.SubScreen.NoteActivity" />

        <activity android:name=".View.SubScreen.EditNoteActivity" />

        <activity
            android:name=".View.BridgeHistory.SexagenaryCycleActivity"
            android:windowSoftInputMode="stateHidden" />

        <activity
            android:name=".View.BridgeHistory.JackpotNumberSetRhythmActivity"
            android:windowSoftInputMode="stateHidden" />

        <activity android:name=".View.SubScreen.CycleByYearActivity" />

        <activity android:name=".View.SubScreen.CalculatingBalanceCoupleActivity" />

        <activity android:name=".View.UpdateDataInfo.UrlAndParamsActivity" />

        <activity android:name=".View.UpdateDataInfo.UrlAndParamsInfoActivity" />

        <activity android:name=".View.UpdateDataInfo.AddJackpotManyYearsActivity" />

        <activity android:name=".View.Setting.NotificationSettingActivity" />

        <activity android:name=".View.Notification.NotificationActivity" />

        <activity android:name=".View.Notification.NewBridgeActivity" />

        <activity android:name=".View.Search.SearchActivity" />

        <activity android:name=".View.Account.SignInActivity" />

        <activity android:name=".View.Account.SignUpActivity" />

        <activity android:name=".View.Account.ChangePasswordActivity" />

    </application>

</manifest>
